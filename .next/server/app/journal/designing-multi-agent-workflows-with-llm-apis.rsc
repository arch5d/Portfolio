ext-muted transition hover:text-accent","children":"Journal"}],["$","$L6","/about",{"href":"/about","className":"text-sm text-muted transition hover:text-accent","children":"About"}],["$","$L6","/creative",{"href":"/creative","className":"text-sm text-muted transition hover:text-accent","children":"Creative"}],["$","$L6","/contact",{"href":"/contact","className":"text-sm text-muted transition hover:text-accent","children":"Contact"}]]}]]}]}],["$","main",null,{"className":"mx-auto max-w-6xl px-6 py-10","children":["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":"404"}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]],"notFoundStyles":[],"styles":null}]}],["$","footer",null,{"className":"mt-20 border-t border-black/5 py-8 text-center text-sm text-muted","children":["$","p",null,{"children":["© ",2026," Archita Dayal · architadayal.in"]}]}]]}]}],null],null],[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/01f1877d82232771.css","precedence":"next","crossOrigin":"$undefined"}]],[null,"$L7"]]]]]
2:["$","article",null,{"className":"mx-auto max-w-3xl space-y-6","children":[["$","p",null,{"className":"text-sm text-muted","children":["2026-02-16"," · ","7 min read"]}],["$","h1",null,{"className":"text-4xl font-semibold","children":"Designing Multi-Agent Workflows with LLM APIs"}],["$","p",null,{"className":"text-muted","children":"A practical structure for splitting reasoning, retrieval, and execution into reliable agents."}],["$","div",null,{"className":"prose prose-neutral max-w-none leading-8","children":[["$","p",null,{"children":"When I first started building with LLM APIs, most of my projects used one large prompt and one model response. It worked for demos, but it did not hold up for larger tasks. As soon as I needed memory, validation, retrieval, and tool calls in one loop, the system became difficult to reason about."}],"\n",["$","p",null,{"children":"A better pattern is to design multi-agent workflows where each agent has one narrow responsibility. Instead of one overloaded prompt, I now use role-specific agents: planner, retriever, executor, and critic."}],"\n",["$","h2",null,{"children":"1) Start with a task graph"}],"\n",["$","p",null,{"children":"Before writing prompts, I define a task graph. Nodes represent operations; edges represent information flow. This helps answer key questions:"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Which components are deterministic?"}],"\n",["$","li",null,{"children":"Which components need model reasoning?"}],"\n",["$","li",null,{"children":"Where should validation happen?"}],"\n"]}],"\n",["$","p",null,{"children":"If the workflow is written as a graph, debugging becomes easier because failures can be localized to one node."}],"\n",["$","h2",null,{"children":"2) Keep agent interfaces strict"}],"\n",["$","p",null,{"children":"Agent autonomy sounds exciting, but unconstrained agents create unpredictable outputs. I prefer strict input-output contracts:"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"hljs language-ts","children":[["$","span",null,{"className":"hljs-keyword","children":"export"}]," ",["$","span",null,{"className":"hljs-keyword","children":"type"}]," ",["$","span",null,{"className":"hljs-title class_","children":"PlannerOutput"}]," = {\r\n  ",["$","span",null,{"className":"hljs-attr","children":"goal"}],": ",["$","span",null,{"className":"hljs-built_in","children":"string"}],";\r\n  ",["$","span",null,{"className":"hljs-attr","children":"subTasks"}],": ",["$","span",null,{"className":"hljs-built_in","children":"string"}],"[];\r\n  ",["$","span",null,{"className":"hljs-attr","children":"dependencies"}],": ",["$","span",null,{"className":"hljs-title class_","children":"Record"}],"<",["$","span",null,{"className":"hljs-built_in","children":"string"}],", ",["$","span",null,{"className":"hljs-built_in","children":"string"}],"[]>;\r\n};\n"]}]}],"\n",["$","p",null,{"children":"Schema-first design keeps downstream systems stable. If one agent changes shape, the parser catches it before state is mutated."}],"\n",["$","h2",null,{"children":"3) Separate context by role"}],"\n",["$","p",null,{"children":"Not every agent needs the full conversation history. A retriever agent benefits from query context, but an evaluator agent may only need expected output criteria and the generated result. Smaller context windows reduce cost and often improve precision."}],"\n",["$","h2",null,{"children":"4) Use a critic, not a loop forever"}],"\n",["$","p",null,{"children":"I avoid unconstrained self-correction loops. Instead, I cap execution at one generation pass and one critic pass. If quality remains low, I return a partial answer with confidence metadata. This is safer than endless retries."}],"\n",["$","h2",null,{"children":"5) Instrument everything"}],"\n",["$","p",null,{"children":"Observability is what makes multi-agent systems practical. I log:"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Prompt versions"}],"\n",["$","li",null,{"children":"Model identity and latency"}],"\n",["$","li",null,{"children":"Token usage by node"}],"\n",["$","li",null,{"children":"Validation failures"}],"\n",["$","li",null,{"children":"User-visible errors"}],"\n"]}],"\n",["$","p",null,{"children":"Without this telemetry, teams confuse model behavior with pipeline bugs."}],"\n",["$","h2",null,{"children":"6) Build for fallbacks"}],"\n",["$","p",null,{"children":"When an agent fails, route to a deterministic fallback whenever possible. For example, retrieval can fall back to lexical search if embedding search times out. User trust improves when systems degrade gracefully."}],"\n",["$","h2",null,{"children":"Closing thought"}],"\n",["$","p",null,{"children":"Multi-agent design is less about hype and more about software architecture. If each agent is treated like a service with contracts, observability, and bounded responsibilities, LLM systems become testable and maintainable."}]]}]]}]
